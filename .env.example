# ============================================================
# Urban Traffic Platform - Environment Variables
# Copy this file to .env in each service directory
# ============================================================

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=urban_traffic

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=7d

# Service Ports
AUTH_SERVICE_PORT=4001
VEHICLE_SERVICE_PORT=4002
TRAFFIC_SERVICE_PORT=4003
INCIDENT_SERVICE_PORT=4004
NOTIFICATION_SERVICE_PORT=4005
GATEWAY_PORT=4000

# Service URLs (for Gateway)
AUTH_SERVICE_URL=http://localhost:4001
VEHICLE_SERVICE_URL=http://localhost:4002
TRAFFIC_SERVICE_URL=http://localhost:4003
INCIDENT_SERVICE_URL=http://localhost:4004
NOTIFICATION_SERVICE_URL=http://localhost:4005

# Node Environment
NODE_ENV=development
